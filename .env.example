# Base URL of the room server (Cloudflare Worker + Durable Objects).
# Local dev default is http://localhost:8787 (wrangler dev).
# Set to your deployed Worker URL in production, e.g.:
#   VITE_ROOM_SERVER=https://battle-royale-rooms.<your-subdomain>.workers.dev
VITE_ROOM_SERVER=http://localhost:8787
