    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "hls.js": "^1.6.16",
    "pitchy": "^4.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
