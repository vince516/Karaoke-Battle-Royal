{
  "name": "battle-royale",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Battle Royale — live singing-contest platform (M1: static parity, React port)",
  "scripts": {
    "dev": "vite",
    "server": "wrangler dev",
    "deploy:server": "wrangler deploy",
    "build": "tsc -b && vite build",
