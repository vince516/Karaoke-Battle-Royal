{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "battle-royale-rooms",
  "main": "worker/index.ts",
  "compatibility_date": "2024-11-01",
  "durable_objects": {
    "bindings": [{ "name": "ROOMS", "class_name": "Room" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["Room"] }],
  "dev": { "port": 8787 }
}
